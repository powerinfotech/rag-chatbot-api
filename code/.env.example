# 복사해서 code/.env 로 사용하세요:  cp .env.example .env

# === Neo4j (docker-compose.yml의 NEO4J_AUTH와 반드시 일치) ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=please_change_me
NEO4J_DATABASE=neo4j

# === Ollama ===
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=gemma4:e2b-it-q4_K_M
LLM_TEMPERATURE=0.2
LLM_NUM_CTX=8192
# 답변 토큰 상한(런어웨이 방지). 한국어는 토큰을 많이 써서 너무 낮추면 답이 잘림. -1이면 무제한
LLM_NUM_PREDICT=1280

# === Embeddings (bge-m3 = 1024차원) ===
EMBED_MODEL=bge-m3
EMBED_DIM=1024

# === Chunking / Retrieval ===
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5
GRAPH_EXPAND_LIMIT=10

# === Data (미설정 시 ../data/판례 국문 자동 사용) ===
# DOCS_DIR=../data/판례 국문

# === CORS (쉼표 구분; '*'면 전체 허용 — 운영에선 프론트 origin만 명시 권장) ===
# 예) CORS_ALLOW_ORIGINS=https://panrye.example.com,https://www.panrye.example.com
CORS_ALLOW_ORIGINS=*
